PORT=5000
REQUEST_BODY_LIMIT=50mb
JWT_SECRET=change_me

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=rentflow_user
DB_PASSWORD=StrongPassword123
DB_NAME=rentflow
DB_SSL=false

API_PUBLIC_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

FASTLIPA_BASE_URL=https://api.fastlipa.com
FASTLIPA_PAY_ENDPOINT=/api/create-transaction
FASTLIPA_STATUS_ENDPOINT=/api/status-transaction
FASTLIPA_LIST_ENDPOINT=/api/list-transaction
FASTLIPA_BALANCE_ENDPOINT=/api/balance
FASTLIPA_API_KEY=your_fastlipa_api_key
FASTLIPA_CURRENCY=TZS
FASTLIPA_MOCK=true
FASTLIPA_DEBUG=false
FASTLIPA_INCLUDE_METADATA=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM="RentFlow TZ <noreply@rentflowtz.com>"
DISABLE_EMAIL=true

STARTER_PRICE_MONTHLY_TZS=500
STARTER_PRICE_YEARLY_TZS=15000
PRO_PRICE_MONTHLY_TZS=500
PRO_PRICE_YEARLY_TZS=15000

RENT_REMINDER_CRON=0 8 * * *
RENT_REMINDER_DAYS_BEFORE=3
ENABLE_LEGACY_RENT_REMINDER=false
COLLECTIONS_AUTOMATION_CRON=30 8 * * *
COLLECTIONS_OVERDUE_DAYS=1,3,7,14
COLLECTIONS_RETRY_DAYS=1,3,7

PLATFORM_TRANSACTION_FEE_PERCENT=2
SMS_COST_TZS=50
SMS_MOCK=true
SMS_PROVIDER=mock
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
BEEM_SMS_URL=https://apisms.beem.africa/v1/send
BEEM_API_KEY=
BEEM_SECRET_KEY=
BEEM_SOURCE_ADDR=INFO
SMS_MAX_RETRIES=3

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
